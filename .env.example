# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Synapse

# Auth — REQUIRED. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth — optional (login page hides the GitHub button when unset)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database — optional for demo-only deploys (defaults to file:./dev.db)
DATABASE_URL=file:./dev.db

# Stripe — optional for demo-only deploys (all Stripe routes return 403 DEMO_MODE)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs — optional for demo-only deploys
# Starter: $9/mo, $86/yr
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
# Pro: $29/mo, $278/yr
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
# Enterprise: $99/mo, $950/yr
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=price_...
